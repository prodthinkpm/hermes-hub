{
  "name": "@hermes-hub/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hermes-hub": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "pnpm --filter @hermes-hub/web build && pnpm --filter @hermes-hub/server build && tsc -p tsconfig.json && node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hermes-hub/core": "workspace:*",
    "@hermes-hub/server": "workspace:*",
    "@hermes-hub/shared": "workspace:*",
    "commander": "^14.0.3",
    "open": "^11.0.0"
  }
}
